/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "skipLibCheck": true,
    "outDir": "./out-tsc/spec",
    "types": ["vitest/globals", "vitest/importMeta", "vite/client", "node"],
    "target": "es2015"
  },
  "include": ["vitest.config.ts", "vitest.shared-config.ts", "vitest.pre-setup.ts", "vitest.setup.ts", "**/*.spec.ts", "**/*.spec.*.ts"]
}
