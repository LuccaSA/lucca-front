{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"moduleResolution": "node",
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": true,
		"declaration": false,
		"types": ["node", "vscode", "jest"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
